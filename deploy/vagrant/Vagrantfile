# -*- mode: ruby -*-
# vi: set ft=ruby :

# Sentinel VMI — Reproducible Deployment Substrate
#
# Pure Cilium authority geometry. No flannel. No hybrid CNI.
# All artifacts synced locally — zero internet dependency during provisioning.
#
# Nodes:
#   control-plane  192.168.50.10  k3s server + Cilium install
#   worker-1       192.168.50.11  k3s agent (joins via deterministic token)

Vagrant.configure("2") do |config|
  config.vm.box = "generic/ubuntu2204"

  config.vm.provider :libvirt do |libvirt|
    libvirt.uri = "qemu:///system"
    libvirt.qemu_use_session = false
    libvirt.storage_pool_name = "images"
    libvirt.memory = 4096
    libvirt.cpus = 4
    libvirt.nested = true
  end

  # Sync the sentinel-vmi root into /vagrant inside each VM.
  # This gives provisioning scripts access to:
  #   /vagrant/k3s          — pre-cached k3s binary (60MB)
  #   /vagrant/install.sh   — k3s install script (local copy)
  #   /vagrant/deploy/vagrant/provision/*.sh — provisioning scripts
  config.vm.synced_folder "../../", "/vagrant", type: "rsync",
    rsync__exclude: [".git/", "tests/", "bench/", "docs/", "capture/"]

  # ── Control Plane ────────────────────────────────────────────────
  config.vm.define "control-plane", primary: true do |cp|
    cp.vm.hostname = "control-plane"
    cp.vm.network "private_network", ip: "192.168.50.10"
    cp.vm.provision "shell", path: "provision/control_plane.sh"
  end

  # ── Worker 1 ─────────────────────────────────────────────────────
  config.vm.define "worker-1" do |w1|
    w1.vm.hostname = "worker-1"
    w1.vm.network "private_network", ip: "192.168.50.11"
    w1.vm.provision "shell", path: "provision/worker.sh"
  end
end
